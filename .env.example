# Port for the Express server (Backend)
PORT=3001

# Sample Dungeon Master PIN. Replace this before inviting players.
# The PIN protects selected DM workflows; it is not full perimeter authentication.
DM_PIN=1234

# Path to the SQLite database file (optional, defaults to ./dnd.db inside the server folder)
# DB_PATH=./dnd.db

# URL of the Ollama instance for AI calculations, item parsing, and rules assistant.
# Prompts are sent to this host when an AI feature is used.
OLLAMA_URL=http://localhost:11434
